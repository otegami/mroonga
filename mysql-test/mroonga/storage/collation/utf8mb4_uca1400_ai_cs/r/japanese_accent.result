DROP TABLE IF EXISTS diaries;
SET NAMES utf8mb4;
CREATE TABLE diaries (
content varchar(256) COLLATE utf8mb4_uca1400_ai_cs,
FULLTEXT INDEX (content)
) DEFAULT CHARSET=utf8mb4;
Warnings:
Warning	138	NormalizerMySQLUnicode normalizer isn't found for utf8mb4_uca1400_ai_cs. Install groonga-normalizer-mysql normalizer. NormalizerAuto is used as fallback.
