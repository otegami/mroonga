INSERT INTO diaries VALUES ('ﾊﾞﾋﾞﾌﾞﾍﾞﾎﾞ');
SELECT * FROM diaries
WHERE MATCH (content) AGAINST ('+バビブベボ' IN BOOLEAN MODE);
